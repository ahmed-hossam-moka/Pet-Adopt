###############################################
# 2. ADMIN — Users Management
###############################################

### Get All Pending Users
GET {{baseUrl}}/admin/pending-users
Authorization: Bearer {{token_admin}}

###

### Approve Shelter Account
PUT {{baseUrl}}/admin/approve-user/7235649d-ae94-46d0-9751-8becb6778bcf
Authorization: Bearer {{token_admin}}

###

### Reject User Account
PUT {{baseUrl}}/admin/reject-user/f5c205cd-0d39-4584-80e0-d7f4b9f4e65a
Authorization: Bearer {{token_admin}}


###############################################
# 3. PETS — Public (No Login)
###############################################

### Get All Approved Pets
GET {{baseUrl}}/pets

###

### Get Pet By Id
GET {{baseUrl}}/pets/24


###

### Search Pets — All Filters
GET {{baseUrl}}/pets/search?animalType=Dog&breed=Husky&maxAge=24&location=Cairo

###

### Search Pets — Only Animal Type
GET {{baseUrl}}/pets/search?animalType=cat

###

### Search Pets — Only Location
GET {{baseUrl}}/pets/search?location=Alex&breed=Husky


### Search Pets — Only Age
GET {{baseUrl}}/pets/search?maxAge=5&location=Cairo


###############################################
# 4. PETS — Owner (Shelter/PetOwner)
###############################################

### Get My Pets
GET {{baseUrl}}/pets/my-pets
Authorization: Bearer {{token_shelter}}

###

### Create New Pet
# @name createPet
POST {{baseUrl}}/pets
Authorization: Bearer {{token_shelter}}
Content-Type: application/json

{
  "name": "Hamada",
  "animalType": "Dog",
  "breed": "Bla Husky",
  "age": 10,
  "gender": "Female",
  "healthStatus": "Vaccinated and healthy",
  "description": "Very friendly and playful dog, looking for a loving home",
  "location": "cairo",
  "ImageUrls": ["https://example.com/dog1.jpg", "https://example.com/dog2.jpg"  ]
}

###

### Update Pet
PUT {{baseUrl}}/pets/1
Authorization: Bearer {{token_shelter}}
Content-Type: application/json

{
  "name": "Buddy Updated",
  "location": "Giza"
}

###

### Delete Pet (Soft Delete)
DELETE {{baseUrl}}/pets/8
Authorization: Bearer {{token_shelter}}


###############################################
# 5. ADMIN — Pets Management
###############################################

### Get All Pending Approval Pets
GET {{baseUrl}}/admin/pending-pets
Authorization: Bearer {{token_admin}}

###

### Approve Pet
PUT {{baseUrl}}/admin/approve-pet/4
Authorization: Bearer {{token_admin}}

###

### Reject Pet
PUT {{baseUrl}}/admin/reject-pet/26
Authorization: Bearer {{token_admin}}


###############################################
# 6. ADOPTER HISTORY
###############################################

### Add History
POST {{baseUrl}}/adopterhistory
Authorization: Bearer {{token_adopter}}
Content-Type: application/json

{
  "previousPetName": "Max",
  "previousPetType": "dog",
  "veterinaryReference": "Dr. Ahmed - 01012345678",
  "experience": "I had a dog for 3 years and took great care of him",
  "yearOfAdoption": 2022
}

###

### Get My Histories
GET {{baseUrl}}/adopterhistory
Authorization: Bearer {{token_adopter}}

###

### Delete History
DELETE {{baseUrl}}/adopterhistory/1
Authorization: Bearer {{token_adopter}}


###############################################
# 7. ADOPTION REQUESTS
###############################################

### Submit Adoption Request
POST {{baseUrl}}/adoption/request
Authorization: Bearer {{token_adopter}}
Content-Type: application/json

{
  "petId": 1,
  "message": "I love this pet and I have experience with dogs"
}

###

### Get My Requests (Adopter)
GET {{baseUrl}}/adoption/my-requests
Authorization: Bearer {{token_adopter}}

###

### Get Requests By Pet (Owner)
GET {{baseUrl}}/adoption/pet/1/requests
Authorization: Bearer {{token_shelter}}

###

### Accept Request (Owner)
PUT {{baseUrl}}/adoption/request/13/accept
Authorization: Bearer {{token_shelter}}

###

### Reject Request (Owner)
PUT {{baseUrl}}/adoption/request/13/reject
Authorization: Bearer {{token_shelter}}


###############################################
# 8. FAVORITES
###############################################

### Add Pet to Favorites by Pet Id
POST {{baseUrl}}/favorites/24
Authorization: Bearer {{token_adopter}}

###

### Get My Favorites 
GET {{baseUrl}}/favorites
Authorization: Bearer {{token_adopter}}

###

### Remove from Favorites by Pet Id
DELETE {{baseUrl}}/favorites/23
Authorization: Bearer {{token_adopter}}


